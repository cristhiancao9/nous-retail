# =============================================
# NOUS RETAIL API — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el .env real al repositorio
# =============================================

# Servidor
PORT=3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI
DB_NAME=software

# JWT — cambia esto por una cadena larga y aleatoria en producción
JWT_SECRET=cambia_esto_por_algo_muy_secreto_en_produccion

# Esquema del tenant principal
TENANT_SCHEMA=nous