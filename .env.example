# =============================================
# NOUS RETAIL API — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el .env real al repositorio
# =============================================

# Servidor
PORT=3000

# CORS — dominio(s) del frontend separados por coma
# Desarrollo: http://localhost:5173
# Producción: https://tu-app.com
CORS_ORIGINS=http://localhost:5173

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI
DB_NAME=software

# JWT — cambia esto por una cadena larga y aleatoria en producción
JWT_SECRET=cambia_esto_por_algo_muy_secreto_en_produccion

# Esquema del tenant principal
TENANT_SCHEMA=nous

# Factus — Facturación Electrónica DIAN
# Sandbox: https://api-sandbox.factus.com.co | Producción: https://api.factus.com.co
FACTUS_URL=https://api-sandbox.factus.com.co
FACTUS_CLIENT_ID=TU_CLIENT_ID
FACTUS_CLIENT_SECRET=TU_CLIENT_SECRET
FACTUS_USERNAME=TU_EMAIL_FACTUS
FACTUS_PASSWORD=TU_PASSWORD_FACTUS
FACTUS_FE_RANGE_ID=   # ID del rango de numeración para Facturas de Venta
FACTUS_NC_RANGE_ID=   # ID del rango de numeración para Notas Crédito